# =============================================================================
# FlowMind AI — Environment Variables
# ⚠️  NUNCA commitees este archivo con valores reales.
#     Usa .env.local para desarrollo local.
#     Usa secrets del proveedor (GitHub Actions, Vault) en producción.
# =============================================================================
#
# Convenciones:
#   🔴 SECRETO  — Valor sensible: rotar periódicamente, no compartir, no loguear
#   🟡 SENSITIVO — Valor que requiere protección, puede exponerse en logs internos
#   🟢 PÚBLICO  — Puede exponerse al frontend (prefijo NEXT_PUBLIC_)
#
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────
# 🔴 SECRETO — Connection string para PostgreSQL.
#     Formato: postgresql://user:password@host:port/database
#     Usa usuario con MÍNIMOS PRIVILEGIOS (no usar superadmin).
DATABASE_URL=postgresql://flowmind:flowmind_pass@localhost:5432/flowmind

# 🟡 SENSITIVO — Pool de conexiones.
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# ─────────────────────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────────────────────
# 🔴 SECRETO — Connection string para Redis.
#     Usa redis:// para conexiones sin TLS, rediss:// para TLS.
REDIS_URL=redis://:flowmind_redis@localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
# 🔴 SECRETO — Contraseña de Redis (requerida en producción).
REDIS_PASSWORD=flowmind_redis

# ─────────────────────────────────────────────────────────────────────────────
# JWT (JSON Web Tokens)
# ─────────────────────────────────────────────────────────────────────────────
# 🔴 SECRETO — Clave para firmar access tokens.
#     Mínimo 32 caracteres, idealmente 64+ caracteres aleatorios.
#     Rotar cada 90 días.
JWT_ACCESS_SECRET=change-me-to-a-random-string-at-least-32-chars-long

# 🔴 SECRETO — Clave para firmar refresh tokens.
#     DEBE ser diferente de JWT_ACCESS_SECRET.
#     Rotar cada 90 días.
JWT_REFRESH_SECRET=change-me-to-another-different-random-string-32-chars

# 🟡 SENSITIVO — Tiempo de expiración de tokens.
#     Access token: 15 minutos (15m) es el valor recomendado.
JWT_ACCESS_EXPIRES_IN=15m

# 🟡 SENSITIVO — Refresh token: máximo 7 días (7d).
JWT_REFRESH_EXPIRES_IN=7d

# 🟡 SENSITIVO — Costo de bcrypt para passwords.
#     12 es el mínimo recomendado. Valores mayores = más seguro pero más lento.
BCRYPT_SALT_ROUNDS=12

# ─────────────────────────────────────────────────────────────────────────────
# Encryption (AES-256-GCM for secrets)
# ─────────────────────────────────────────────────────────────────────────────
# 🔴 SECRETO — Clave de cifrado AES-256-GCM.
#     DEBE ser exactamente 64 caracteres hexadecimales (32 bytes, 256 bits).
#     Usar:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#     Rotar cada 90 días.
#     ⚠️  Si pierdes esta clave, NO PUEDES recuperar secrets cifrados.
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ─────────────────────────────────────────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────────────────────────────────────────
# 🔴 SECRETO — API Key de OpenAI.
#     Formato: sk-... (comienza con sk-, mínimo 20 caracteres).
OPENAI_API_KEY=sk-your-openai-api-key

# 🟢 PÚBLICO — Modelo por defecto.
OPENAI_MODEL=gpt-4o
# 🟡 SENSITIVO — Límites de tokens y temperatura.
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.2

# ─────────────────────────────────────────────────────────────────────────────
# Anthropic (fallback AI provider)
# ─────────────────────────────────────────────────────────────────────────────
# 🔴 SECRETO — API Key de Anthropic (opcional, usado como fallback).
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-opus-20240229
ANTHROPIC_MAX_TOKENS=4096

# ─────────────────────────────────────────────────────────────────────────────
# Connectors: Slack
# ─────────────────────────────────────────────────────────────────────────────
# 🔴 SECRETO — Slack App credentials (opcional, solo si usas el connector).
SLACK_CLIENT_ID=
# 🔴 SECRETO
SLACK_CLIENT_SECRET=
# 🔴 SECRETO — Usado para verificar firmas HMAC de webhooks entrantes de Slack.
SLACK_SIGNING_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Connectors: Gmail
# ─────────────────────────────────────────────────────────────────────────────
# 🔴 SECRETO — Google OAuth credentials (opcional, solo si usas el connector).
GMAIL_CLIENT_ID=
# 🔴 SECRETO
GMAIL_CLIENT_SECRET=
# 🔴 SECRETO
GMAIL_REFRESH_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────
# 🟢 PÚBLICO — URL base de la aplicación (expuesta al frontend).
#     En producción: DEBE ser HTTPS.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 🟢 PÚBLICO — Nombre de la aplicación.
NEXT_PUBLIC_APP_NAME=FlowMind AI

# 🟡 SENSITIVO — Entorno de ejecución.
#     Producción: production | Desarrollo: development | Tests: test
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# Socket.io
# ─────────────────────────────────────────────────────────────────────────────
SOCKETIO_PATH=/api/socket
SOCKETIO_CORS_ORIGIN=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# BullMQ (Background Jobs)
# ─────────────────────────────────────────────────────────────────────────────
BULLMQ_PREFIX=flowmind
BULLMQ_DEFAULT_ATTEMPTS=3
# 🟡 SENSITIVO — Backoff: exponential o fixed.
BULLMQ_BACKOFF_TYPE=exponential
BULLMQ_BACKOFF_DELAY=2000

# ─────────────────────────────────────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────────────────────────────────────
# 🟡 SENSITIVO — Ventana de rate limiting en milisegundos (default: 60000 = 1 min).
RATE_LIMIT_WINDOW_MS=60000
# 🟡 SENSITIVO — Máximo de requests por ventana (default: 100).
RATE_LIMIT_MAX_REQUESTS=100

# ─────────────────────────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────────────────────────
# 🟡 SENSITIVO — Orígenes permitidos para CORS (separados por coma).
#     En producción: solo dominios controlados, con HTTPS.
#     Ejemplo: https://app.flowmind.ai,https://admin.flowmind.ai
CORS_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────
# 🟡 SENSITIVO — Nivel de logging.
#     Producción: info | Desarrollo: debug
LOG_LEVEL=debug

# 🟢 PÚBLICO — Pretty print (solo desarrollo).
LOG_PRETTY=true

# ─────────────────────────────────────────────────────────────────────────────
# Sentry (Error Tracking)
# ─────────────────────────────────────────────────────────────────────────────
# 🟡 SENSITIVO — DSN de Sentry para error tracking (opcional).
#     ⚠️  Configurar PII stripping en Sentry dashboard.
SENTRY_DSN=

# ─────────────────────────────────────────────────────────────────────────────
# Webhooks
# ─────────────────────────────────────────────────────────────────────────────
# 🟡 SENSITIVO — Tamaño máximo de payload de webhook en bytes.
#     Default: 262144 (256 KB). Máximo: 1048576 (1 MB).
WEBHOOK_PAYLOAD_MAX_BYTES=262144

# 🟡 SENSITIVO — Timeout de webhooks en milisegundos.
#     Default: 10000 (10s). Máximo: 60000 (60s).
WEBHOOK_TIMEOUT_MS=10000

# =============================================================================
# IMPORTANTE: Seguridad
# =============================================================================
# 1. JAMÁS uses los valores por defecto de este ejemplo en producción.
# 2. Rota JWT_ACCESS_SECRET, JWT_REFRESH_SECRET y ENCRYPTION_KEY cada 90 días.
# 3. No compartas .env por Slack, email, o ningún canal no seguro.
# 4. No loguees valores de variables marcadas como 🔴 SECRETO.
# 5. Usa un password manager de equipo (1Password, Bitwarden) para compartir secrets.
# =============================================================================
